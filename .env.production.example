# ─── Production Environment Variables ─────────────────
# Copy to .env.production and fill in real values
# WARNING: Never commit secrets to git!

# ─── Domain / URLs ────────────────────────────────────
FRONTEND_URL=https://your-domain.com
APP_URL=https://your-domain.com
VITE_API_URL=https://your-domain.com
VITE_WS_URL=wss://your-domain.com/ws/collab
VITE_NOTIFICATION_WS_URL=wss://your-domain.com/ws/notifications
EXTERNAL_PORT=80
EXTERNAL_SSL_PORT=443

# ─── Database ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ─── JWT Secrets (generate: openssl rand -base64 32) ──
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# ─── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# ─── Google Books API ─────────────────────────────────
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# ─── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=BookClubs <noreply@bookclubs.app>

# ─── Grafana ──────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME
